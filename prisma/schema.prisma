//#region Configs
generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

//#endregion

//#region Enums
enum WeekDay {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
}

enum NotificationType {
  FRIEND_REQUEST
  FRIEND_ACCEPTED
  POWERUP_RECEIVED
  LEVEL_UP
  ACHIEVEMENT_UNLOCKED
  CHALLENGE_INVITE
  COMMENT_RECEIVED
  TAGGED_IN_ACTIVITY
  PERSONAL_RECORD_BROKEN
}

enum XpReason {
  WORKOUT_COMPLETED
  PERSONAL_RECORD
  STREAK_7_DAYS
  STREAK_30_DAYS
  POWERUP_GIVEN
  POWERUP_RECEIVED
  FRIEND_ACCEPTED
  CHALLENGE_COMPLETED
  CHALLENGE_WON
  COMMENT_GIVEN
}

enum ChallengeType {
  GLOBAL
  FRIEND_DUEL
}

enum ChallengeStatus {
  PENDING
  ACTIVE
  COMPLETED
}

//#endregion

//#region User
model User {
  id                    String         @id
  workoutPlans          WorkoutPlan[]
  name                  String
  email                 String
  emailVerified         Boolean        @default(false)
  image                 String?
  friendCode            String?        @unique
  xp                    Int            @default(0)
  level                 Int            @default(1)
  isPublicProfile       Boolean        @default(true)
  showStats             Boolean        @default(true)
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  sessions              Session[]
  accounts              Account[]
  trainData             UserTrainData?
  friends               Friendship[]   @relation("UserFriends")
  friendOf              Friendship[]   @relation("FriendOfUser")
  activities            Activity[]
  taggedInActivities    Activity[]     @relation("ActivityTags")
  powerupsGiven         Powerup[]      @relation("UserGivenPowerups")
  comments              Comment[]
  personalRecords       PersonalRecord[]
  bodyProgressLogs      BodyProgressLog[]
  notificationsReceived Notification[] @relation("RecipientNotifications")
  notificationsSent     Notification[] @relation("SenderNotifications")
  xpTransactions        XpTransaction[]
  achievements          UserAchievement[]
  challengesParticipated ChallengeParticipant[]
  challengesCreated     Challenge[]    @relation("ChallengeCreator")

  @@unique([email])
  @@map("user")
}

model Friendship {
  id        String           @id @default(uuid())
  userId    String
  friendId  String
  status    FriendshipStatus @default(PENDING)
  user      User             @relation("UserFriends", fields: [userId], references: [id], onDelete: Cascade)
  friend    User             @relation("FriendOfUser", fields: [friendId], references: [id], onDelete: Cascade)
  createdAt DateTime         @default(now()) @db.Timestamptz()
  updatedAt DateTime         @updatedAt @db.Timestamptz()

  @@unique([userId, friendId])
  @@map("friendship")
}

model Activity {
  id               String         @id @default(uuid())
  userId           String
  workoutDayId     String
  workoutSessionId String         @unique
  statusMessage    String?
  imageUrl         String?
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  workoutDay       WorkoutDay     @relation(fields: [workoutDayId], references: [id], onDelete: Cascade)
  workoutSession   WorkoutSession @relation(fields: [workoutSessionId], references: [id], onDelete: Cascade)
  powerups         Powerup[]
  comments         Comment[]
  taggedUsers      User[]         @relation("ActivityTags")
  notifications    Notification[]
  createdAt        DateTime       @default(now()) @db.Timestamptz()

  @@map("activity")
}

model Comment {
  id         String   @id @default(uuid())
  activityId String
  userId     String
  content    String
  createdAt  DateTime @default(now()) @db.Timestamptz()
  updatedAt  DateTime @updatedAt @db.Timestamptz()

  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("comment")
}

model PersonalRecord {
  id            String   @id @default(uuid())
  userId        String
  exerciseName  String
  weightInGrams Int
  reps          Int
  achievedAt    DateTime @default(now()) @db.Timestamptz()
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, exerciseName])
  @@map("personal_record")
}

model BodyProgressLog {
  id                  String   @id @default(uuid())
  userId              String
  weightInGrams       Int
  heightInCentimeters Int
  age                 Int
  bodyFatPercentage   Float
  loggedAt            DateTime @default(now()) @db.Timestamptz()
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, loggedAt])
  @@map("body_progress_log")
}

model Powerup {
  id         String   @id @default(uuid())
  activityId String
  userId     String
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  user       User     @relation("UserGivenPowerups", fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now()) @db.Timestamptz()

  @@unique([activityId, userId])
  @@map("powerup")
}

model Notification {
  id            String           @id @default(uuid())
  recipientId   String
  senderId      String?
  type          NotificationType
  activityId    String?
  achievementId String?
  content       String?
  isRead        Boolean          @default(false)
  createdAt     DateTime         @default(now()) @db.Timestamptz()
  updatedAt     DateTime         @updatedAt @db.Timestamptz()

  recipient   User         @relation("RecipientNotifications", fields: [recipientId], references: [id], onDelete: Cascade)
  sender      User?        @relation("SenderNotifications", fields: [senderId], references: [id], onDelete: SetNull)
  activity    Activity?    @relation(fields: [activityId], references: [id], onDelete: Cascade)
  achievement Achievement? @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@map("notification")
}

model XpTransaction {
  id        String   @id @default(uuid())
  userId    String
  amount    Int
  reason    XpReason
  relatedId String?
  createdAt DateTime @default(now()) @db.Timestamptz()
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, reason, relatedId])
  @@map("xp_transaction")
}

model Achievement {
  id            String            @id @default(uuid())
  name          String
  description   String
  iconUrl       String?
  xpReward      Int               @default(0)
  users         UserAchievement[]
  notifications Notification[]

  @@map("achievement")
}

model UserAchievement {
  id            String   @id @default(uuid())
  userId        String
  achievementId String
  unlockedAt    DateTime @default(now()) @db.Timestamptz()
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@map("user_achievement")
}

model Challenge {
  id          String          @id @default(uuid())
  name        String
  description String
  type        ChallengeType
  status      ChallengeStatus @default(PENDING)
  startDate   DateTime?       @db.Timestamptz()
  endDate     DateTime?       @db.Timestamptz()
  creatorId   String?
  xpReward    Int             @default(0)
  
  creator      User?          @relation("ChallengeCreator", fields: [creatorId], references: [id], onDelete: SetNull)
  participants ChallengeParticipant[]

  @@map("challenge")
}

model ChallengeParticipant {
  id          String   @id @default(uuid())
  challengeId String
  userId      String
  joinedAt    DateTime @default(now()) @db.Timestamptz()
  score       Int      @default(0)
  hasWon      Boolean  @default(false)

  challenge   Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([challengeId, userId])
  @@map("challenge_participant")
}

model UserTrainData {
  id                  String   @id @default(uuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weightInGrams       Int
  heightInCentimeters Int
  age                 Int
  bodyFatPercentage   Float
  createdAt           DateTime @default(now()) @db.Timestamptz()
  updatedAt           DateTime @updatedAt @db.Timestamptz()

  @@map("user_train_data")
}

//#endregion

//#region Workout
model WorkoutPlan {
  id          String       @id @default(uuid())
  name        String
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  workoutDays WorkoutDay[]
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now()) @db.Timestamptz()
  updatedAt   DateTime     @updatedAt @db.Timestamptz()

  @@map("workout_plan")
}

model WorkoutDay {
  id                         String            @id @default(uuid())
  name                       String
  workoutPlanId              String
  workoutPlan                WorkoutPlan       @relation(fields: [workoutPlanId], references: [id], onDelete: Cascade)
  isRestDay                  Boolean           @default(false)
  weekDay                    WeekDay
  exercises                  WorkoutExercise[]
  sessions                   WorkoutSession[]
  coverImageUrl              String?
  estimatedDurationInSeconds Int
  createdAt                  DateTime          @default(now()) @db.Timestamptz()
  updatedAt                  DateTime          @updatedAt @db.Timestamptz()
  activities                 Activity[]

  @@map("workout_day")
}

model WorkoutExercise {
  id                String     @id @default(uuid())
  name              String
  order             Int
  workoutDayId      String
  workoutDay        WorkoutDay @relation(fields: [workoutDayId], references: [id], onDelete: Cascade)
  sets              Int
  reps              Int
  restTimeInSeconds Int
  createdAt         DateTime   @default(now()) @db.Timestamptz()
  updatedAt         DateTime   @updatedAt @db.Timestamptz()
  loggedSets        WorkoutSet[]

  @@map("workout_exercise")
}

model WorkoutSession {
  id           String       @id @default(uuid())
  workoutDayId String
  workoutDay   WorkoutDay   @relation(fields: [workoutDayId], references: [id], onDelete: Cascade)
  startedAt    DateTime     @db.Timestamptz()
  completedAt  DateTime?    @db.Timestamptz()
  createdAt    DateTime     @default(now()) @db.Timestamptz()
  updatedAt    DateTime     @updatedAt @db.Timestamptz()
  activity     Activity?
  sets         WorkoutSet[]

  @@map("workout_session")
}

model WorkoutSet {
  id                String         @id @default(uuid())
  sessionId         String
  workoutExerciseId String
  setIndex          Int
  weightInGrams     Int
  reps              Int
  createdAt         DateTime       @default(now()) @db.Timestamptz()
  updatedAt         DateTime       @updatedAt @db.Timestamptz()

  session         WorkoutSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  workoutExercise WorkoutExercise @relation(fields: [workoutExerciseId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([workoutExerciseId])
  @@map("workout_set")
}

//#endregion

//#region Better Auth
model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

//#endregion
